export DOTSCRIPTS="$HOME/.config/shell"
export EDITOR="nano"
[ -d "/Applications/Visual Studio Code.app/Contents/Resources/app/bin" ] && export VISUAL="code --wait"
export PAGER="less"
export LC_ALL=$LANG

export GOBIN="$(go env GOPATH)/bin"
export PNPMBIN="$HOME/Library/pnpm"
export TFBIN="$HOME/bin"
export PATH="$GOBIN:$PNPMBIN:$TFBIN:$PATH"

# Avoid insecure permissions warning after Homebrew updates, https://workbrew.com/docs/how-to-fix-zsh-errors-after-installing-workbrew
export ZSH_DISABLE_COMPFIX=true
export NVM_AUTO_USE=true
export NVM_COMPLETION=true
export SSH_AUTH_SOCK="$HOME/Library/Group\ Containers/2BUA8C4S2C.com.1password/t/agent.sock"
export TF_PRODUCT="terraform"
export ZOXIDE_CMD_OVERRIDE="cd"

source $HOMEBREW_PREFIX/share/antigen/antigen.zsh
zstyle :omz:plugins:iterm2 shell-integration yes #?
antigen init $HOME/.antigenrc

source $HOME/.config/op/plugins.sh
source $DOTSCRIPTS/aliases.sh

# Enable shell completions
eval "$(op completion zsh)"; compdef _op op
eval "$(uv generate-shell-completion zsh)"
eval "$(uvx --generate-shell-completion zsh)"
[[ "$TERM_PROGRAM" == "kiro" ]] && . "$(kiro --locate-shell-integration-path zsh)"

# Sign-in to 1Password if no session
if ! op whoami >/dev/null 2>&1; then
    eval $(op signin --account grendel.1password.com)
fi
